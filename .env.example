# =============================================================================
# Purse — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -- Interswitch Sandbox Credentials --
ISW_CLIENT_ID=your_sandbox_client_id
ISW_SECRET_KEY=your_sandbox_secret_key
ISW_PASSPHRASE=your_sandbox_passphrase
ISW_BASE_URL=https://qa.interswitchng.com
ISW_PAYMENT_URL=https://qa.interswitchng.com/collections/api/v1/pay

# -- Database --
DATABASE_URL=postgresql://user:password@localhost:5432/purse_db
REDIS_URL=redis://localhost:6379

# -- AI / ML --
OPENAI_API_KEY=your_openai_api_key

# -- Blockchain (Polygon Mumbai Testnet) --
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
WALLET_PRIVATE_KEY=your_testnet_wallet_private_key
CONTRACT_SAVINGS_LEDGER=deployed_contract_address
CONTRACT_WAG_POOL=deployed_contract_address

# -- SMS / Notifications --
SMS_API_KEY=your_sms_provider_key
SMS_SENDER_ID=Purse

# -- App Config --
NODE_ENV=development
PORT=3000
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d
OTP_EXPIRY_MINUTES=10

# -- Frontend --
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
