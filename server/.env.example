# ═══════════════════════════════════════════════════════════════
# Purse — Server Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file: cp .env.example .env
# Then fill in your actual credentials below.

# ─── General ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────
# Option 1 (free): https://supabase.com → New project → Settings → Database → Connection string
# Option 2 (free): https://neon.tech → Create project → Connection string
DATABASE_URL=postgresql://user:password@localhost:5432/purse_db

# ─── Redis (Cache & Sessions) ────────────────────────────────
# Free: https://upstash.com → Create Redis database → REST URL
REDIS_URL=redis://localhost:6379

# ─── Authentication ──────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_32_char_secret_here
JWT_EXPIRY=7d
OTP_EXPIRY_MINUTES=10

# ═══════════════════════════════════════════════════════════════
# INTERSWITCH APIs — SANDBOX (No account needed for testing!)
# Docs: https://docs.interswitchgroup.com/docs/home
# ═══════════════════════════════════════════════════════════════

# ─── Shared Sandbox Credentials (ready to use) ───────────────
# These are Interswitch's public sandbox keys for testing.
# For production, create your own at: https://developer.interswitchgroup.com
# If OTP signup fails, use these sandbox keys or contact: support@Interswitchng.com

ISW_CLIENT_ID=IKIAB23A4E2756605C1ABC33CE3C287E27267F660D61
ISW_SECRET_KEY=secret
ISW_MERCHANT_CODE=MX6072
ISW_PAY_ITEM_ID=9405967
ISW_BASE_URL=https://qa.interswitchng.com
ISW_PAYMENT_URL=https://newwebpay.qa.interswitchng.com/collections/w/pay
ISW_PASSPORT_URL=https://qa.interswitchng.com/passport/oauth/token
ISW_INLINE_CHECKOUT=https://newwebpay.qa.interswitchng.com/inline-checkout.js

# ─── Alternative Card Payment Sandbox Credentials ────────────
# Use these if you need the Card Payment API (v3) specifically
# ISW_CLIENT_ID=IKIA3B827951EA3EC2E193C51DA1D22988F055FD27DE
