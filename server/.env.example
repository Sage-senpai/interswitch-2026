# ═══════════════════════════════════════════════════════════════
# Purse — Server Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file: cp .env.example .env
# Then fill in your actual credentials below.

# ─── General ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────
# Sign up free: https://supabase.com (or https://neon.tech)
# Create a new project → Settings → Database → Connection string
DATABASE_URL=postgresql://user:password@localhost:5432/purse_db

# ─── Redis (Cache & Sessions) ────────────────────────────────
# Sign up free: https://upstash.com
# Create a Redis database → Details → REST URL
REDIS_URL=redis://localhost:6379

# ─── Authentication ──────────────────────────────────────────
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_32_char_secret_here
JWT_EXPIRY=7d
OTP_EXPIRY_MINUTES=10

# ─── Interswitch APIs ────────────────────────────────────────
# SIGN UP HERE: https://developer.interswitchgroup.com
# 1. Create an account
# 2. Go to "My Apps" → Create new application
# 3. Select APIs: Payment Gateway (IPG), Quickteller, Transfer
# 4. Copy your Client ID and Secret Key from the app dashboard
# 5. Use sandbox/QA base URL for testing
ISW_CLIENT_ID=your_interswitch_client_id
ISW_SECRET_KEY=your_interswitch_secret_key
ISW_PASSPHRASE=your_interswitch_passphrase
ISW_BASE_URL=https://qa.interswitchng.com
ISW_PAYMENT_URL=https://qa.interswitchng.com/collections/api/v1/pay

# ─── AI / OpenAI ─────────────────────────────────────────────
# Sign up: https://platform.openai.com
# Go to API Keys → Create new key
OPENAI_API_KEY=sk-your_openai_api_key

# ─── Blockchain (Polygon) ────────────────────────────────────
# RPC Provider — Sign up free: https://www.alchemy.com (or https://www.infura.io)
# 1. Create account → Create app → Select "Polygon Amoy" testnet
# 2. Copy the HTTPS endpoint
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_key

# Wallet for deploying contracts
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Fund with test MATIC: https://faucet.polygon.technology
WALLET_PRIVATE_KEY=your_testnet_wallet_private_key

# Contract addresses (fill after deployment)
CONTRACT_SAVINGS_LEDGER=
CONTRACT_WAG_POOL=
