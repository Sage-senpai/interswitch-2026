# ─── Test Cards ──────────────────────────────────────────────
# Verve:      5061050254756707864  | Exp: 06/26 | CVV: 111 | PIN: 1111
# Verve:      5060990580000217499  | Exp: 03/50 | CVV: 111 | PIN: 1111
# VISA:       4000000000002503     | Exp: 03/50 | CVV: 11  | PIN: 1111
# Mastercard: 5123450000000008     | Exp: 01/39 | CVV: 100 | PIN: 1111 | OTP: 123456
# Default OTP for all: 123456

# ─── AI / OpenAI ─────────────────────────────────────────────
# Sign up: https://platform.openai.com/api-keys
# Note: AI advisor has a fallback mode that works WITHOUT an API key
OPENAI_API_KEY=

# ─── Blockchain (Polygon) ────────────────────────────────────
# RPC Provider (free): https://www.alchemy.com → Create app → Polygon Amoy testnet
# Alt: https://www.infura.io
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_key

# Wallet for contracts
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Fund with test MATIC: https://faucet.polygon.technology
WALLET_PRIVATE_KEY=

# Contract addresses (fill after deployment)
CONTRACT_SAVINGS_LEDGER=
CONTRACT_WAG_POOL=
